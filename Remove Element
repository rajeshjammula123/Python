class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:
        # k will track the position for the next non-val element
        k = 0
        
        for i in range(len(nums)):
            # If the current element is NOT the one we want to remove
            if nums[i] != val:
                nums[k] = nums[i]
                k += 1
                
        # k now represents the number of elements not equal to val
        return k
