class Solution:
    def threeSumClosest(self, nums: list[int], target: int) -> int:
        nums.sort()
        n = len(nums)
        # Initialize with the first possible triplet sum
        closest_sum = nums[0] + nums[1] + nums[2]
        
        for i in range(n - 2):
            # Optimization: Skip duplicate values for the first element
            if i > 0 and nums[i] == nums[i-1]:
                continue
                
            left, right = i + 1, n - 1
            
            while left < right:
                current_sum = nums[i] + nums[left] + nums[right]
                
                if current_sum == target:
                    return current_sum
                
                # Update closest_sum if the current_sum is nearer to target
                if abs(target - current_sum) < abs(target - closest_sum):
                    closest_sum = current_sum
                
                # Move pointers based on current_sum relative to target
                if current_sum < target:
                    left += 1
                else:
                    right -= 1
                    
        return closest_sum
