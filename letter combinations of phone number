class Solution:
    def letterCombinations(self, digits: str) -> list[str]:
        if not digits:
            return []
        
        # Mapping of digits to letters
        phone_map = {
            "2": "abc", "3": "def", "4": "ghi", "5": "jkl",
            "6": "mno", "7": "pqrs", "8": "tuv", "9": "wxyz"
        }
        
        res = []
        
        def backtrack(index, current_combination):
            # Base case: If the current combination is the same length as digits
            if len(current_combination) == len(digits):
                res.append(current_combination)
                return
            
            # Get the letters corresponding to the current digit
            letters = phone_map[digits[index]]
            
            # Iterate through the letters and move to the next digit
            for letter in letters:
                backtrack(index + 1, current_combination + letter)
        
        # Start backtracking from the first digit
        backtrack(0, "")
        return res
