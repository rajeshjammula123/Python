class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        if not nums:
            return 0
        
        # 'l' is the index of the last unique element found
        l = 0
        
        # 'r' scans the rest of the array
        for r in range(1, len(nums)):
            # If we find a value different from our last unique element
            if nums[r] != nums[l]:
                l += 1
                nums[l] = nums[r]
        
        # The number of unique elements is the index + 1
        return l + 1
